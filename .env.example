# Copy this file to .env and adjust values as needed.
# All variables have defaults — this file is optional.

# Host port for the mock Prometheus backend
MOCK_BACKEND_PORT=9090

# Host port for the MongoDB mock Prometheus backend
MOCK_MONGO_PORT=9093

# Host port for the MongoDB Atlas mock Prometheus backend
MOCK_MONGO_ATLAS_PORT=9095

# Host port for the probe engine API
PROBE_ENGINE_PORT=8000

# Host port for the MongoDB probe engine API
PROBE_ENGINE_MONGO_PORT=8002

# Host port for the MongoDB Atlas probe engine API
PROBE_ENGINE_MONGO_ATLAS_PORT=8004

# Host port for the live MongoDB instance
MONGO_LIVE_PORT=27018

# Host port for the live MongoDB exporter
MONGODB_EXPORTER_PORT=9216

# Host port for Prometheus scraping live MongoDB
PROMETHEUS_MONGO_LIVE_PORT=9097

# Host port for the live MongoDB faultable Prometheus proxy
FAULT_PROXY_MONGO_LIVE_PORT=9098

# Host port for the live MongoDB probe engine API
PROBE_ENGINE_MONGO_LIVE_PORT=8006

# Host port for the fault-controller API
FAULT_CONTROLLER_PORT=8010

# Host port for the demo UI simulator
SIMULATOR_PORT=8080

# Host port for real Prometheus (scrapes probe engine)
PROMETHEUS_PORT=9091

# Host port for Grafana (anonymous auth, no login)
GRAFANA_PORT=3000
