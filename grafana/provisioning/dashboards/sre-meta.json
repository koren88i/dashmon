{
  "id": null,
  "uid": "sre-service-health-01",
  "title": "[SRE] Service Health",
  "description": "Meta-dashboard monitoring the health of 'Service Health'",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Probe Metrics",
          "value": "probe-metrics"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Health Score",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "uid": "${datasource}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dashboard_health_score{dashboard_uid=\"service-health-01\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 1.0
              }
            ]
          },
          "noValue": "N/A",
          "unit": "percentunit",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Active Issues",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "uid": "${datasource}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(dashboard_panel_status{dashboard_uid=\"service-health-01\", probe_type!=\"query\"} == 0) or vector(0)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "noValue": "N/A"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Estimated Load Time",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "uid": "${datasource}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dashboard_load_time_seconds{dashboard_uid=\"service-health-01\"}"
