      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "noValue": "N/A",
          "unit": "s",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Last Probe Run",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "uid": "${datasource}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - dashboard_health_score{dashboard_uid=\"service-health-01\"}"
