      "datasource": {
        "uid": "${datasource}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "p50_1",
          "expr": "histogram_quantile(0.5, rate(dashboard_panel_query_duration_seconds_bucket{dashboard_uid=\"service-health-01\", panel_id=\"1\"}[5m]))",
          "legendFormat": "Request Rate p50"
        },
        {
          "refId": "p50_2",
          "expr": "histogram_quantile(0.5, rate(dashboard_panel_query_duration_seconds_bucket{dashboard_uid=\"service-health-01\", panel_id=\"2\"}[5m]))",
          "legendFormat": "Error Rate % p50"
        },
        {
          "refId": "p50_3",
          "expr": "histogram_quantile(0.5, rate(dashboard_panel_query_duration_seconds_bucket{dashboard_uid=\"service-health-01\", panel_id=\"3\"}[5m]))",
