              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "noValue": "No data yet",
          "unit": "s",
          "decimals": 0
        },
        "overrides": []
      }
    },
