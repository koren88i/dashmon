          "instant": true
        }
      ],
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Event Time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "dashboard_uid": true,
              "event_id": true,
              "instance": true,
              "job": true,
              "panel_id": true
            },
            "indexByName": {
              "Value": 0,
              "panel_title": 1,
              "error_type": 2,
              "message": 3
            },
            "renameByName": {
              "Value": "Event Time",
              "panel_title": "Panel",
              "error_type": "Type",
              "message": "Message"
            }
          }
        }
