{
  "id": null,
  "uid": "sre-mongodb-ops-01",
  "title": "[SRE] MongoDB Operations",
  "description": "Meta-dashboard monitoring the health of 'MongoDB Operations'",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "sre_datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Probe Metrics",
          "value": "probe-metrics"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Overview",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Health Score",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "uid": "${sre_datasource}",
        "type": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dashboard_health_score{dashboard_uid=\"mongodb-ops-01\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 1.0
              }
            ]
          },
          "noValue": "N/A",
          "unit": "percentunit",
          "decimals": 0
        },
        "overrides": []
      }
    },
